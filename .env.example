# ─ Discord ─
TOKEN=your_discord_bot_token_here
BOT_ROLE_ID=your_bot_role_id
MEMBER_ROLE_ID=your_member_role_id
WELCOME_CHANNEL_ID=your_welcome_channel_id

# ─ Reddit Feed ─
REDDIT_WELCOME_CHANNEL_ID=your_reddit_feed_channel_id
# webhook display name
REDDIT_WEBHOOK_NAME=r/WelcomeToTheNHK

# ─ Wiki Recent Changes ─
WIKI_RC_CHANNEL_ID=your_wiki_rc_channel_id
# hide minor edits
WIKI_RC_HIDE_MINOR=0
# hide bot edits
WIKI_RC_HIDE_BOTS=0
# Comma-separated list of page titles to ignore
WIKI_RC_IGNORE_PAGES="Welcome to the NHK Wiki:Sandbox"
# webhook display name
WIKI_RC_WEBHOOK_NAME=f/WelcomeToTheNHK